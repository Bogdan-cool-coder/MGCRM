# =============================================================================
# Root .env — docker-compose.yml reads this (place next to docker-compose.yml).
# This file is committed as an example. Copy to .env and fill in real values.
# .env is gitignored — never commit it.
#
# NOTE ON PORTS: frontend/nginx/postgres/redis do NOT publish host ports in
# production. Traefik reaches the frontend container via the proxy docker
# network directly on internal port 80. Use `docker compose exec` for DB admin.
# =============================================================================

# --- Docker / Compose ---
COMPOSE_PROJECT_NAME=macro-crm
IMAGE_TAG=latest                      # dev-latest | latest | <git-sha7>

# --- Domain + Traefik ---
# Server: root@153.80.193.132 (Selectel VPS, Ubuntu, Traefik v2.11.42)
# DNS A-record mgcrm.macroglobal.tech → 153.80.193.132 MUST exist before first
# deploy; Let's Encrypt will fail to issue a certificate without it.
APP_DOMAIN=mgcrm.macroglobal.tech

# Name of the existing external Traefik docker network on this VPS.
# Confirmed on server: docker network ls → "proxy" (created by Traefik).
TRAEFIK_NETWORK=proxy

# Name of the Let's Encrypt certresolver in Traefik static config.
# Confirmed on server: /opt/traefik/traefik.yml → certresolver "letsencrypt".
TRAEFIK_CERTRESOLVER=letsencrypt

# --- Database credentials (also referenced in src/.env) ---
# Keep in sync with DB_DATABASE / DB_USERNAME / DB_PASSWORD in src/.env.
# postgres/redis publish NO host ports — access only via docker compose exec.
DB_DATABASE=macro_crm
DB_USERNAME=macro_crm
DB_PASSWORD=__SET_ME__
