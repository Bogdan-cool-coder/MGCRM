# =============================================================================
# Root .env — docker-compose.yml reads this (place next to docker-compose.yml).
# This file is committed as an example. Copy to .env and fill in real values.
# .env is gitignored — never commit it.
# =============================================================================

# --- Docker / Compose ---
COMPOSE_PROJECT_NAME=macro-crm
IMAGE_TAG=latest                      # dev-latest | latest | <git-sha7>
APP_BIND=127.0.0.1                    # keep 127.0.0.1 — Traefik reaches the app via docker network

# Host-side port bindings (loopback only — for debug / health-check).
# Traefik does NOT use these ports; it reaches the frontend container via the
# traefik-public network directly.
APP_PORT=8080                         # nginx (backend php-fpm proxy)
FRONTEND_PORT=3000                    # frontend (SPA nginx) — Traefik → container :80
POSTGRES_HOST_PORT=5432               # postgres (loopback debug access)
REDIS_HOST_PORT=6379                  # redis (loopback debug access)

# --- Domain + Traefik (SERVER-SPECIFIC — ask your DevOps / check Traefik config) ---
APP_DOMAIN=mgcrm.macroglobal.tech

# Name of the existing external Traefik docker network on this VPS.
# Find it with: docker network ls | grep traefik
# Common names: traefik-public, proxy, traefik
TRAEFIK_NETWORK=traefik-public

# Name of the Let's Encrypt certresolver defined in Traefik's static config.
# Check traefik.yml or traefik.toml on the VPS.
# Common names: letsencrypt, le, myresolver
TRAEFIK_CERTRESOLVER=letsencrypt

# --- Database credentials (also referenced in src/.env) ---
# Keep in sync with DB_DATABASE / DB_USERNAME / DB_PASSWORD in src/.env
DB_DATABASE=macro_crm
DB_USERNAME=macro_crm
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
