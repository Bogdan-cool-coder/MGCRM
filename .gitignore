# === Проект (Laravel API в src/, Vue SPA во front/) ===
/src/vendor/
/src/node_modules/
/src/.env
/src/.env.backup
/src/.phpunit.result.cache
/src/storage/*.key
/src/storage/framework/cache/*
/src/storage/framework/sessions/*
/src/storage/framework/views/*
/src/storage/logs/*
/src/public/build/
/src/public/hot

/front/node_modules/
/front/dist/
/front/.vite/

# === examples/ — ПОЛНЫЕ КОПИИ-ЭТАЛОНЫ, КОММИТЯТСЯ ЦЕЛИКОМ (нелокальная работа). ===
# Это чистые source-клоны (без composer-vendor/node_modules) — НИЧЕГО не игнорируем,
# чтобы дубли репозиториев (vizion + contracts) лежали на гите полностью:
# исходники, конфиги, lang/vendor (Laravel-переводы пакетов), .env.example и т.д.
# (если когда-то внутри examples появится тяжёлый build — добавить точечный ignore вручную)

