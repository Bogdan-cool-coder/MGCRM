# =============================================================================
# Vizion — root .env (docker-compose reads this)
# Place next to docker-compose.yml in ~/vizion/dev/ or ~/vizion/prod/
# =============================================================================

# --- Docker / Compose ---
COMPOSE_PROJECT_NAME=vizion-dev       # vizion-dev | vizion-prod
IMAGE_TAG=dev-latest                  # dev-latest | prod-latest | dev-<sha7> | prod-<sha7>
APP_BIND=127.0.0.1                    # bind address for host-exposed ports (keep 127.0.0.1, host nginx proxies)
APP_PORT=2020                         # host port → container nginx :80 (dev: 2020, prod: 2021)
FRONTEND_PORT=3030                    # host port → frontend container :5173 (dev: 3030, prod: 3031)
POSTGRES_HOST_PORT=5420               # host port → postgres :5432 (dev: 5420, prod: 5421)

# --- Laravel ---
APP_NAME=Vizion
APP_ENV=local                         # local (dev) | production (prod)
APP_KEY=                              # generate: php artisan key:generate
APP_DEBUG=true                        # dev: true, prod: false
APP_URL=https://devizion.macroglobal.tech

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

# --- PostgreSQL (Vizion DB) ---
DB_CONNECTION=pgsql
DB_HOST=postgres                      # docker service name
DB_PORT=5432
DB_DATABASE=vizion_dev                # vizion_dev | vizion_prod
DB_USERNAME=vizion
DB_PASSWORD=CHANGE_ME

# --- MacroData (external MySQL, read-only) ---
# Credentials are stored per-company in the companies table.
# No global .env config needed — leave blank.

# --- AI (Prism cascade) ---
AI_PROVIDER=glm                       # glm (GLM-5 via Z.AI) | anthropic (Claude Sonnet)
AI_MODEL=glm-5.1
PRISM_REQUEST_TIMEOUT=120
Z_API_KEY=
Z_URL=https://api.z.ai/api/coding/paas/v4
ANTHROPIC_API_KEY=

# --- Sanctum ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
# Only set if SPA uses cookie-based Sanctum session. Bearer-only frontend does not need this.
# SANCTUM_STATEFUL_DOMAINS=devizion.macroglobal.tech

# --- Cache / Queue ---
CACHE_STORE=database
# Use `database` for dev/prod (queue-worker container picks jobs off the
# postgres `jobs` table). Use `sync` only inside non-CI scripts that need
# inline job execution.
QUEUE_CONNECTION=database
# Seconds before a reserved-but-unfinished job is released back to the queue.
# Must be > queue:work --timeout (600s) to avoid double-processing AI jobs.
# (ProcessChatMessageJob $timeout=600 + ShouldBeUnique $uniqueFor=600.)
DB_QUEUE_RETRY_AFTER=900

# --- Filesystem ---
FILESYSTEM_DISK=local
