APP_NAME=Vizion
APP_ENV=testing
APP_KEY=base64:6PY5Hx7aRRfyqaR8NtrJ1GQasYuV/SpfJ4B9F8ZkXBE=
APP_DEBUG=true
APP_URL=http://localhost

# CRITICAL: tests MUST run against an isolated in-memory sqlite DB. The
# dev/prod stack runs pgsql `vizion` on the `postgres` container, and a
# RefreshDatabase trait against that connection wipes the live data.
# A guard in tests/TestCase.php aborts the suite if DB_CONNECTION is not sqlite.
DB_CONNECTION=sqlite
DB_DATABASE=:memory:
DB_HOST=
DB_PORT=
DB_USERNAME=
DB_PASSWORD=

BCRYPT_ROUNDS=4
CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array
BROADCAST_CONNECTION=null

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

TELESCOPE_ENABLED=false
PULSE_ENABLED=false
NIGHTWATCH_ENABLED=false

AI_PROVIDER=glm
AI_MODEL=glm-5.1
PRISM_REQUEST_TIMEOUT=5
Z_API_KEY=test-key-not-used
Z_URL=http://localhost
ANTHROPIC_API_KEY=
