APP_NAME=Vizion
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=vizion_dev
DB_USERNAME=vizion
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# AI chat (config/ai.php)
# =============================================================================
# Provider API keys. Both are read by Prism (vendor/prism-php config) directly
# from env. Z.AI powers the GLM fallback stage; Anthropic powers the primary
# (Claude) stage of every cascade. ANTHROPIC_API_KEY is REQUIRED now that
# Claude is the primary model for report/widget/document/quick_qa generation.
Z_API_KEY=                       # Z.AI (GLM) API key — required for the GLM-5.1 fallback
ANTHROPIC_API_KEY=               # Anthropic API key — required (Claude is primary)

# Home provider namespace + global default model. Cascades are mixed-provider
# (Anthropic primary → GLM-5.1 fallback), so AI_PROVIDER only selects which
# namespace supplies retry/timeout policy and the context-overflow rescue
# target — leave it 'glm'. Set AI_PROVIDER=anthropic to force Claude-only.
# AI_PROVIDER=glm
# AI_MODEL=glm-5.1               # generic default model (rarely needed)

# Per-cascade primary model overrides. The hardcoded config defaults are the
# intended production targets (Sonnet for tools, Haiku for quick_qa); only set
# these to point a specific environment at a different model without redeploy.
# AI_REPORT_MODEL=claude-sonnet-4-6
# AI_WIDGET_MODEL=claude-sonnet-4-6
# AI_DOCUMENT_MODEL=claude-sonnet-4-6
# AI_QUICKQA_MODEL=claude-haiku-4-5-20251001
# AI_FALLBACK_MODEL=glm-5.1      # shared GLM fallback model (2nd stage of every cascade)

# Cross-provider context-overflow fallback. When a GLM fallback stage trips
# GLM's input window (HTTP 400 code 1261), re-run the request against the
# bigger-window Anthropic cascade. Enabled by default; requires ANTHROPIC_API_KEY.
# AI_CONTEXT_OVERFLOW_FALLBACK=true
# AI_CONTEXT_OVERFLOW_FALLBACK_PROVIDER=anthropic

# Dry-run policy for AI-generated reports. When enabled, each create_report /
# update_report tool invocation runs ReportDataService::getData() immediately
# after the Report is saved; a failing fetch tags Report.metadata.dry_run_failed
# = true and is hidden from ReportController::index. max_semantic_retries caps
# how many consecutive failed dry-runs the LLM may attempt in a single chat
# turn before the tool injects a stop-trying directive.
# AI_DRY_RUN_ENABLED=true
# AI_DRY_RUN_MAX_RETRIES=2

# =============================================================================
# Reports (config/reports.php)
# =============================================================================
# Hard cap for GET /api/reports/{id}/dashboard-data — maximum rows returned
# without truncation. When the underlying dataset exceeds this value the
# service flags meta.dashboard_limited=true. Default 5000.
REPORTS_DASHBOARD_LIMIT=5000

# =============================================================================
# Docker / Compose (used by docker-compose.yml, not by Laravel itself)
# These must be set in the root .env (next to docker-compose.yml), NOT here.
# Listed here as documentation only.
# =============================================================================
# COMPOSE_PROJECT_NAME=vizion-dev
# IMAGE_TAG=dev-latest
# APP_BIND=127.0.0.1
# APP_PORT=2020
# FRONTEND_PORT=3030
# POSTGRES_HOST_PORT=5420
