# === Domain (Traefik) ===
DOMAIN=contracts.macroglobal.tech

# === Database ===
DB_USER=contracts
DB_PASSWORD=changeme_long_random_string
DB_NAME=contracts

# === Auth ===
JWT_SECRET=changeme_use_openssl_rand_hex_64
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=12

# === First admin (создаётся при первом запуске, если ещё нет) ===
ADMIN_EMAIL=b.yadykin@macroglobaltech.com
ADMIN_PASSWORD=1z2x3c4v
ADMIN_NAME=Богдан Ядыкин

# === Telegram ===
TELEGRAM_BOT_TOKEN=<токен от @BotFather>
TELEGRAM_APPROVAL_CHAT_ID=  # заполнить после добавления бота в чат и получения id через @RawDataBot
# RUN_TELEGRAM_POLLING — где запускать long-polling. В проде НЕ задаётся в .env:
# compose ставит api=false (масштабируется в 2 реплики), а поллер живёт в отдельном
# bot-сервисе. Локально (один процесс) флаг по умолчанию true — менять не нужно.

# === Google Drive (service account) ===
# JSON грузится через UI /admin/integrations в writable storage volume.
# Путь задан в docker-compose.yml (GOOGLE_SERVICE_ACCOUNT_JSON_PATH).
# Здесь оставлять не нужно — переопределяется compose-ом.

# === App ===
APP_ENV=production
LOG_LEVEL=INFO
TZ=Asia/Almaty
PUBLIC_BASE_URL=https://contracts.macroglobal.tech

# === Storage ===
STORAGE_PATH=/data/storage  # volume в контейнере api для .docx/.pdf

# === Epic 16 — Security: Redis (rate-limit + last_used debounce) ===
# В compose redis-сервис задан; api/bot переопределяют REDIS_URL=redis://redis:6379/0.
# Локально (без docker) можно оставить пусто — graceful fallback на noop.
REDIS_URL=redis://redis:6379/0

# === Epic 16 — Security: 2FA TOTP ===
# Fernet ключ для шифрования TOTP secret'ов в БД. Генерится один раз через:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 44 base64-URL-safe символа. ОБЯЗАТЕЛЕН для работы 2FA — без него /api/auth/2fa/* отдают 503.
TOTP_ENCRYPTION_KEY=

# === Epic 16 — Security: SSO (Google + Yandex OAuth 2.0) ===
# Google: создать OAuth client в console.cloud.google.com → APIs & Services → Credentials.
# Redirect URI: https://contracts.macroglobal.tech/api/auth/sso/google/callback
# Если CLIENT_ID пуст — /api/auth/sso/google/* отдают 503 и кнопка скрыта в UI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Google Workspace domain. Ограничивает SSO только сотрудниками этого домена
# (по hd claim). Пусто = разрешён любой Google-аккаунт.
GOOGLE_ALLOWED_HD=macroglobaltech.com

# Yandex: создать app в oauth.yandex.ru/client/new.
# Redirect URI: https://contracts.macroglobal.tech/api/auth/sso/yandex/callback
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# === Epic 18 — AI Features (Contract Analysis + Deal Prefill) ===
# Anthropic Claude API key для AI-эндпоинтов:
#   POST /api/contracts/{id}/ai-analyze
#   POST /api/deals/{id}/ai-prefill
#   POST /api/leads/{id}/ai-prefill
# Если пусто → эндпоинты возвращают 503 «AI not configured» (graceful — UI
# показывает понятное сообщение, кнопка disabled). Ключ берётся в console.anthropic.com.
# Модель по умолчанию — claude-sonnet-4-5 (можно переопределить).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# === Sentry (мониторинг ошибок frontend) — опционально ===
# Если NEXT_PUBLIC_SENTRY_DSN пуст — Sentry ПОЛНОСТЬЮ выключен (no-op): ни client,
# ни server init не выполняются, бандл собирается как раньше. DSN — публичный,
# инлайнится в JS-бандл на этапе `docker compose build web` (это НЕ секрет).
# NEXT_PUBLIC_SENTRY_DSN=https://<public-key>@<org>.ingest.sentry.io/<project-id>
# NEXT_PUBLIC_SENTRY_ENV=production
#
# Source-map upload (опционально, только в CI). Включается ТОЛЬКО когда заданы
# ВСЕ три: SENTRY_AUTH_TOKEN + SENTRY_ORG + SENTRY_PROJECT. Без них аплоад
# пропускается, билд не падает. AUTH_TOKEN — секрет (хранить в GHA secrets, не в .env).
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# === OnlyOffice (WYSIWYG-редактор master_skeleton.docx) — опционально ===
# Пока не задано — фича выключена (эндпоинты 503, кнопка в UI скрыта). Чтобы включить:
#   1) DNS: A-record office.contracts.macroglobal.tech → IP сервера (для TLS Let's Encrypt)
#   2) Раскомментировать строки ниже (секрет — openssl rand -hex 32)
#   3) docker compose --profile onlyoffice pull onlyoffice && docker compose --profile onlyoffice up -d onlyoffice
# COMPOSE_PROFILES=onlyoffice
# ONLYOFFICE_ENABLED=true
# ONLYOFFICE_JWT_SECRET=changeme_openssl_rand_hex_32
# ONLYOFFICE_DOMAIN=office.contracts.macroglobal.tech
# ONLYOFFICE_PUBLIC_URL=https://office.contracts.macroglobal.tech
# ONLYOFFICE_IMAGE=onlyoffice/documentserver:8.2.2  # лучше закрепить версию вместо latest
# Внутренние URL (DS↔api по docker-сети) трогать не нужно — дефолты в config.py:
# ONLYOFFICE_INTERNAL_API_URL=http://api:8000   ONLYOFFICE_INTERNAL_DS_URL=http://onlyoffice
