# MACRO CRM — пример .env для локальной разработки.
#
# Скопируй этот файл в apps/api/.env (для backend) и используй
# `docker compose -f docker-compose.dev.yml up -d db` чтобы поднять Postgres локально.
#
# НЕ коммить настоящие секреты — это пример для разработки.

# ----- Подключение к локальной БД (из docker-compose.dev.yml) -----
DATABASE_URL=postgresql+asyncpg://macro:macro@localhost:5432/macro_dev

# ----- Auth / JWT -----
JWT_SECRET=dev-secret-replace-in-production
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin
ADMIN_NAME=Local Admin

# ----- App config -----
APP_ENV=development
LOG_LEVEL=INFO
PUBLIC_BASE_URL=http://localhost:3000
STORAGE_PATH=./storage
TEMPLATES_PATH=./templates/contracts_master

# ----- Telegram (опционально — для локального теста бота) -----
TELEGRAM_BOT_TOKEN=
RUN_TELEGRAM_POLLING=false

# ----- OnlyOffice (опционально — локально обычно не нужен) -----
ONLYOFFICE_JWT_SECRET=
ONLYOFFICE_INTERNAL_URL=
ONLYOFFICE_PUBLIC_URL=

# ----- Google Drive (опционально — для теста выгрузки) -----
GOOGLE_SERVICE_ACCOUNT_JSON_PATH=
GOOGLE_DRIVE_PARENT_FOLDER_ID=

# ----- Claude API (опционально — для эпика 7 локально) -----
ANTHROPIC_API_KEY=
