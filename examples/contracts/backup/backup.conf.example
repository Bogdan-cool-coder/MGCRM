# ================================================================
# Backup system config — sourced by all 3 scripts. ONLY file that
# changes per-project. Copy to backup.conf on the VPS (chmod 600).
# Real secrets (DB_PASSWORD / Telegram tokens / S3 keys) are NOT here —
# scripts read them from ENV_FILE at runtime.
# ================================================================

PROJECT_NAME="macro-contracts"          # filename prefix + Telegram messages

DB_CONTAINER="macro-contracts-db"       # docker container (Postgres, stable name)
DB_NAME="contracts"
DB_USER="contracts"

DEPLOY_DIR="/opt/macro-contracts"       # compose project root (for storage tar + backend stop)
BACKUP_DIR="/opt/macro-contracts/backups"
ENV_FILE="/opt/macro-contracts/.env"    # has DB_PASSWORD + TELEGRAM_ALERT_* (+ optional S3_*)

RETENTION_DAYS=30
TEST_DB_NAME="contracts_restore_test"   # restore.sh test target (NO hyphen — valid PG identifier)

# ─── Telegram: which env vars hold the bot token + chat id ───
# MACRO uses a dedicated alert bot. Scripts map these → TELEGRAM_BOT_TOKEN/CHAT_ID.
TG_TOKEN_ENV="TELEGRAM_ALERT_BOT_TOKEN"
TG_CHAT_ENV="TELEGRAM_ALERT_CHAT_ID"

# ─── Storage volume backup (MACRO-specific: договоры .docx/.pdf, аватары, шаблон) ───
STORAGE_BACKUP=1
STORAGE_SERVICE="api"                   # compose service that mounts /data/storage

# ─── Production restore: which compose services to stop/start ───
BACKEND_SERVICES="api web bot"

# ─── S3 / B2 off-site (optional — TODO for MACRO, local-only for now) ───
# Leave blank to skip. Put real secrets in ENV_FILE (S3_BUCKET/S3_ENDPOINT/
# S3_ACCESS_KEY/S3_SECRET_KEY), scripts read them from env.
S3_BUCKET="${S3_BUCKET:-}"
S3_ENDPOINT="${S3_ENDPOINT:-}"
S3_ACCESS_KEY="${S3_ACCESS_KEY:-}"
S3_SECRET_KEY="${S3_SECRET_KEY:-}"
