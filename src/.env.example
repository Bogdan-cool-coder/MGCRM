APP_NAME="MACRO Global CRM"
APP_ENV=local                       # prod: production
APP_KEY=                            # generate: php artisan key:generate
APP_DEBUG=true                      # prod: false
APP_URL=http://localhost:8080       # prod: https://mgcrm.macroglobal.tech

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# Database (PostgreSQL 16 — primary). sqlite is used ONLY by the test suite.
# =============================================================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=macro_crm
DB_USERNAME=macro_crm
DB_PASSWORD=

# =============================================================================
# Sessions / cache / queue — Redis-backed (queue + cache; sessions in DB).
# =============================================================================
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis
# CACHE_PREFIX=

# =============================================================================
# Redis (NET-NEW vs Vizion) — queue + cache backend. Uses predis client.
# =============================================================================
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================================
# Sanctum — Bearer personal access tokens (SPA stores the token).
# =============================================================================
# Comma-separated stateful domains are NOT used (token-based, not cookie SPA),
# but kept here for reference. Token TTL in MINUTES. LEAVE BLANK = never expires
# (the only correct prod value — the SPA stores the token and must not be logged
# out mid-session). A non-empty value here makes EVERY token expire after that
# many minutes, so do not set e.g. "1"/"3" unless a finite TTL is truly intended.
SANCTUM_TOKEN_EXPIRATION=
# SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173

# =============================================================================
# TOTP 2FA (config/2fa.php) — secret + backup codes encrypted on APP_KEY.
# =============================================================================
TWOFA_ISSUER="MACRO Global CRM"
TWOFA_WINDOW=1
TWOFA_BACKUP_CODES=8

# =============================================================================
# Admin seed (AdminSeeder, M0.4) — dev bootstrap account.
# =============================================================================
ADMIN_EMAIL=admin@mgcrm.test
ADMIN_PASSWORD=password
ADMIN_NAME="MGCRM Admin"

# =============================================================================
# AI cascade (config/ai.php) — Anthropic-only. Not called during Sprint 0.
# =============================================================================
ANTHROPIC_API_KEY=
# AI_PROVIDER=anthropic
# AI_REPORT_MODEL=claude-sonnet-4-6
# AI_WIDGET_MODEL=claude-sonnet-4-6
# AI_DOCUMENT_MODEL=claude-sonnet-4-6
# AI_QUICKQA_MODEL=claude-haiku-4-5-20251001

# =============================================================================
# Google SSO (wired in the cross-cutting Integrations sprint, not Foundation).
# =============================================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# =============================================================================
# Mail (SMTP). Defaults to log driver in dev.
# =============================================================================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@mgcrm.test"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# Telegram bot (S2.9 — approval channel + account linking).
#   TELEGRAM_BOT_TOKEN       — Bot API token (boevoy in src/.env).
#   TELEGRAM_BOT_USERNAME    — bot @username, used to build the t.me deeplink.
#   TELEGRAM_APPROVAL_CHAT_ID— group chat id where approval cards are posted.
#   TELEGRAM_LINK_TTL_MINUTES— one-shot link-token TTL (default 10).
#   TELEGRAM_WEB_BASE_URL    — base for "Открыть в системе" links (default APP_URL).
#   RUN_TELEGRAM_POLLING     — true ONLY in the dedicated `bot` container.
#                              A parallel getUpdates elsewhere → Telegram 409.
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_APPROVAL_CHAT_ID=
TELEGRAM_LINK_TTL_MINUTES=10
TELEGRAM_WEB_BASE_URL=
RUN_TELEGRAM_POLLING=false

# =============================================================================
# SalesPulse bot (Slice 3 — sales-oversight bot, SECOND bot on its OWN token).
#   SALESPULSE_BOT_TOKEN   — Bot API token for the SalesPulse bot (distinct from
#                            TELEGRAM_BOT_TOKEN). Empty → FakeNutgram fallback.
#   SALESPULSE_RUN_POLLING — true ONLY in the dedicated `salespulse-bot` container.
#                            A parallel getUpdates on this token → Telegram 409.
#   SALESPULSE_TIMEZONE    — day-window TZ for plan/fact (default Asia/Dubai).
#   SALESPULSE_TEAMS_JSON  — JSON array of teams (spec §8):
#     [{"chat_id":"-100...","name":"MACRO Global","pipelines":[<id>...],
#       "admins":["Bogdan_MACRO"],
#       "managers":[{"user_id":<id>,"tg":"ilyarogov","name":"Илья Рогов"}]}]
# =============================================================================
SALESPULSE_BOT_TOKEN=
SALESPULSE_RUN_POLLING=false
SALESPULSE_TIMEZONE=Asia/Dubai
SALESPULSE_TEAMS_JSON=[]
# Private-chat TEST MODE (config-gated; OFF in prod). Lets a test admin drive the
# bot in a 1-on-1 DM with the test bot on the seeded test accounts (manager1/2/3
# @mgcrm.test from SalesPulseDemoSeeder) without a configured group chat.
#   SALESPULSE_TEST_MODE   — enable the private-chat path (default false).
#   SALESPULSE_TEST_ADMINS — csv of tg usernames allowed to drive the test team.
SALESPULSE_TEST_MODE=false
SALESPULSE_TEST_ADMINS=Bogdan_MACRO

# =============================================================================
# Gotenberg (PHPWord → PDF). URL injected by docker-compose into app +
# queue-worker; documented here for non-docker dev.
# =============================================================================
GOTENBERG_URL=http://gotenberg:3000

# =============================================================================
# AMO → MGCRM migration (TEMPORARY — Domain/Migration, dropped at M12).
# One-off EXTRACT phase reads AMO API v4 into JSONL staging on disk.
# =============================================================================
# AMO account subdomain — base url becomes https://<subdomain>.amocrm.ru/api/v4
AMO_MIGRATION_SUBDOMAIN=macro
# SECRET — fill on the server only. Long-lived AMO integration Bearer token.
AMO_MIGRATION_TOKEN=
# Account-wide request throttle (req/s). AMO caps ~7/s; 6 leaves prod headroom.
AMO_MIGRATION_RATE_LIMIT_RPS=6

VITE_APP_NAME="${APP_NAME}"

# =============================================================================
# Sentry (error + performance monitoring — sentry/sentry-laravel)
# =============================================================================
# DSN from the Sentry project (Settings > Client Keys). Leave EMPTY to fully
# disable the SDK (local/CI). main fills the real value; never commit it.
SENTRY_LARAVEL_DSN=
# Performance trace sampling, 0.0-1.0. Default 0.2 (20%); lower in prod if noisy.
SENTRY_TRACES_SAMPLE_RATE=0.2
# Release identifier — the deploy pipeline sets this to the git SHA. Leave empty.
SENTRY_RELEASE=
# Environment label. Left empty → falls back to APP_ENV (local/staging/production).
# SENTRY_ENVIRONMENT=
# PII guard: keep FALSE — MG CRM stores personal data. Do not enable without review.
# SENTRY_SEND_DEFAULT_PII=false

# =============================================================================
# Docker / Compose (set in the ROOT .env next to docker-compose.yml, NOT here).
# Listed for documentation only — do NOT duplicate in src/.env.
# =============================================================================
# COMPOSE_PROJECT_NAME=macro-crm
# IMAGE_TAG=latest
# APP_BIND=127.0.0.1
# APP_PORT=8080
# FRONTEND_PORT=3000
# POSTGRES_HOST_PORT=5432
# REDIS_HOST_PORT=6379
# DB_DATABASE=macro_crm
# DB_USERNAME=macro_crm
# DB_PASSWORD=<strong password>
#
# --- Traefik integration (server-specific, set in root .env on VPS) ---
# APP_DOMAIN=mgcrm.macroglobal.tech
# TRAEFIK_NETWORK=<name of external Traefik docker network on this VPS>
# TRAEFIK_CERTRESOLVER=<name of Let's Encrypt resolver in Traefik config>
