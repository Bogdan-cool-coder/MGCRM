# Test environment — third leg of the triple DB isolation (see tests/TestCase.php
# and phpunit.xml). Pins sqlite :memory: so the PHPUnit suite can never reach a
# live database. phpunit.xml <env force="true"> and TestCase::createApplication()
# putenv() reinforce this even if docker injects pgsql vars into the container.
APP_ENV=testing
APP_KEY=base64:5I6Oy6JfcGx73Pr0QNzPPLi9jv9weUdPJDzW7j/aho8=
APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=4

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array
BROADCAST_CONNECTION=null

TELESCOPE_ENABLED=false
PULSE_ENABLED=false
