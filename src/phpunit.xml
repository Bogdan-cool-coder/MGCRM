<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <!--
            force="true" is CRITICAL here. Without it, phpunit <env> entries do NOT
            override values that already exist in the runtime env (or get pulled in
            from .env / .env.testing via LoadEnvironmentVariables). That regression
            previously caused RefreshDatabase to wipe the live pgsql DB on a dev
            stack — DB_CONNECTION leaked through as `pgsql` because docker-compose
            injects it into the container env. Do not remove.
            A complementary guard in tests/TestCase.php aborts the suite if the
            default DB connection is not sqlite at runtime (triple isolation:
            phpunit force + TestCase putenv-before-bootstrap + setUp abort-guard).
        -->
        <env name="APP_ENV" value="testing" force="true"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file" force="true"/>
        <env name="BCRYPT_ROUNDS" value="4" force="true"/>
        <env name="BROADCAST_CONNECTION" value="null" force="true"/>
        <env name="CACHE_STORE" value="array" force="true"/>
        <env name="DB_CONNECTION" value="sqlite" force="true"/>
        <env name="DB_DATABASE" value=":memory:" force="true"/>
        <env name="DB_URL" value="" force="true"/>
        <env name="DB_HOST" value="" force="true"/>
        <env name="DB_PORT" value="" force="true"/>
        <env name="DB_USERNAME" value="" force="true"/>
        <env name="DB_PASSWORD" value="" force="true"/>
        <env name="MAIL_MAILER" value="array" force="true"/>
        <env name="QUEUE_CONNECTION" value="sync" force="true"/>
        <env name="SESSION_DRIVER" value="array" force="true"/>
        <env name="PULSE_ENABLED" value="false" force="true"/>
        <env name="TELESCOPE_ENABLED" value="false" force="true"/>
        <env name="NIGHTWATCH_ENABLED" value="false" force="true"/>
        <!-- Sentry stays a no-op in tests: empty DSN disables the SDK so the
             suite never ships events to an external service. -->
        <env name="SENTRY_LARAVEL_DSN" value="" force="true"/>
    </php>
</phpunit>
