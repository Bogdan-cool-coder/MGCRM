{
  "name": "mgcrm-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --ext .ts,.vue",
    "lint:fix": "eslint . --ext .ts,.vue --fix",
    "format": "prettier --write .",
    "lint:ds": "stylelint --config .stylelintrc.vue.json \"src/**/*.vue\" && stylelint --config .stylelintrc.scss.json \"src/**/*.scss\"",
    "lint:ds:react": "oxlint --config ../.claude/skills/macroglobal-design/_adherence.oxlintrc.json --ignore-pattern '**/theme/**' src"
  },
  "dependencies": {
    "@primevue/themes": "^4.5.4",
    "@sentry/vue": "^8.55.2",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.3",
    "@vue-flow/core": "^1.48.2",
    "@vue-flow/minimap": "^1.5.4",
    "axios": "^1.13.6",
    "bootstrap": "^5.3.8",
    "decimal.js": "^10.6.0",
    "dompurify": "^3.4.10",
    "echarts": "^6.1.0",
    "marked": "^18.0.5",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.4.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "vue": "^3.5.29",
    "vue-advanced-cropper": "^2.8.9",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "^10.0.8",
    "vue-router": "^5.0.3",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^3.6.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.11.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/eslint-config-typescript": "^14.8.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "jiti": "^2.7.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "^1.70.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "stylelint": "^17.13.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-declaration-strict-value": "^1.11.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
