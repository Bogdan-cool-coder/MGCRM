# Frontend environment — copy to .env.local and fill in values
# NEVER commit real values to the repository

# Laravel Reverb WebSocket (optional — omit or leave blank to disable live updates)
# VITE_REVERB_APP_KEY mirrors REVERB_APP_KEY (public key — never expose APP_SECRET or APP_ID here).
# VITE_REVERB_HOST is the public WSS host (e.g. mgcrm.macroglobal.tech).
# VITE_REVERB_PORT is the proxy port (usually 443).
# When these vars are absent the app works normally — live updates are simply disabled.
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=
VITE_REVERB_PORT=443

# Sentry error tracking (optional — omit or leave blank to disable)
# Runtime: injected into Vite bundle via import.meta.env
VITE_SENTRY_DSN=
# Release tag matched to git tag / CI build number (e.g. mg-crm-web@1.2.3)
VITE_SENTRY_RELEASE=

# Build-time: used by @sentry/vite-plugin to upload source-maps after build.
# Required only in CI/CD — NOT needed for local dev or staging without source-map upload.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Set to "false" to disable source-map generation entirely (e.g. prod deploy without Sentry)
# VITE_SOURCEMAP=false
